{
  "name": "invoice-generator",
  "version": "1.0.0",
  "description": "Professional offline invoicing and financial tracking application",
  "main": "dist/main/index.js",
  "author": {
    "name": "Mir Faizan",
    "email": "techbytesdesign@gmail.com"
  },
  "scripts": {
    "setup": "npm install --ignore-scripts && node node_modules/electron/install.js",
    "dev": "concurrently -n RENDERER,ELECTRON -c cyan,yellow \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "npm run build:main && vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "@fontsource/inter": "^5.0.18",
    "lucide-react": "^0.379.0",
    "qrcode": "^1.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "recharts": "^2.12.7",
    "sql.js": "^1.14.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "jimp": "^0.22.12",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.techbytesdesign.invoicegenerator",
    "productName": "InvoiceGenerator",
    "copyright": "Copyright © 2026 Tech Bytes Design",
    "directories": {
      "output": "dist-app",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/sql.js/dist/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "InvoiceGenerator",
      "license": "build/LICENSE.txt"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    }
  }
}
